# 목적: AssetTechHub 모노레포에서 추적하면 안 되는 로컬 산출물을 제외한다.
# 설명: npm workspaces(ui, backend), Next.js, Vite, Vitest, SQLite 개발 산출물 기준의 공통 규칙이다.
# 적용 범위: 프로젝트 루트와 하위 워크스페이스 전체에 공통 적용한다.

# 의존성 디렉터리
node_modules/
**/node_modules/

# 빌드 및 개발 산출물
.next/
**/.next/
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
.vite/
**/.vite/
.turbo/
**/.turbo/
*.tsbuildinfo

# 테스트 및 리포트 산출물
test-results/
playwright-report/

# 로그
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 로컬 환경 변수 및 개인 설정
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
*.local

# SQLite 개발 데이터
/data/mock.db
/data/mock.db-shm
/data/mock.db-wal

# 에디터 및 운영체제 파일
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
