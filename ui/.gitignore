# 목적: UI 워크스페이스에서 추적하지 않을 로컬 산출물을 제외한다.
# 설명: Vite, Vitest, TypeScript, 에디터 임시 파일 기준의 규칙이다.

# 의존성 디렉터리
node_modules/

# 빌드 및 테스트 산출물
dist/
dist-ssr/
coverage/
.vite/
*.tsbuildinfo

# 로그
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 로컬 환경 설정
.env
.env.*
!.env.example
!.env.*.example
*.local

# 에디터 및 운영체제 파일
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
